{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Private Workspace",
  "version": "0.1.117",
  "identifier": "local.ai-private-workspace",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Private Workspace",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI workspace for private project onboarding.",
    "longDescription": "AI Private Workspace runs local project analysis, local model setup, and safe agent planning without uploading private project data.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../../build/desktop/frozen-backend-runtime",
      "../../build/desktop/llama-runtime"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tonkonozhenko-mi/ai_private_workspace/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwMjdBQjBENDcwMzE1MTYKUldRV0ZRTkhEYXNuY0dtOVdrZ0hQUW5NL1RvNlhLYUVRaCtiSWM1ZlFsNVlTUzJtcWQ1aHB1TDEK"
    }
  }
}
