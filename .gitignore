# Local runtime data. Do not commit or overwrite these during update archives.
backend/.ai-workbench/
*.db
*.sqlite
*.sqlite3

# Python / frontend build artifacts (match at any depth)
**/.venv/
**/__pycache__/
*.pyc
**/.pytest_cache/
**/node_modules/
frontend/dist/

# Generated desktop package artifacts. Ignore build/ contents rather than the
# directory node itself, so the tracked eval fixture below can be re-included
# (git can't re-include a path whose parent directory is excluded outright).
build/*
# The eval demo repo is a stable fixture the golden-set label CI test reads, so it
# stays tracked even though the rest of build/ is generated and ignored.
!build/demo-project/
dist/
# Virtual environments and caches
.venv/
backend/.venv/
backend/.venv-x86_64/
frontend/.vite/
*.tsbuildinfo
.DS_Store

# Local environment files (e.g. backend/.env for local dev config)
.env
**/.env
!*.env.example

# Release archives are generated artifacts
build/release/
frontend/src-tauri/target/

# IDE and OS metadata
.idea/
**/.DS_Store
# Linux virtiofs/NFS placeholder files left by some editors/sync layers
**/.fuse_hidden*

# Guard: never re-commit accidental nested project copies
frontend/frontend/
frontend/backend/
backend/.venv_t/

# Raw, unredacted screenshot drop — never commit (may contain names/paths/tickets)
/assets/screenshots/

# Local design mockups (not part of the app)
/answer_trace_mockup.html
/project_brain_mockup.html
