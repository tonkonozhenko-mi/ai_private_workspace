# Local runtime data. Do not commit or overwrite these during update archives.
backend/.ai-workbench/
*.db
*.sqlite
*.sqlite3

# Python / frontend build artifacts (match at any depth)
**/.venv/
**/__pycache__/
*.pyc
**/.pytest_cache/
**/node_modules/
frontend/dist/

# Generated desktop package artifacts
build/
dist/
# Virtual environments and caches
.venv/
backend/.venv/
backend/.venv-x86_64/
frontend/.vite/
*.tsbuildinfo
.DS_Store

# Local environment files (e.g. backend/.env for local dev config)
.env
**/.env
!*.env.example

# Release archives are generated artifacts
build/release/
frontend/src-tauri/target/

# IDE and OS metadata
.idea/
**/.DS_Store

# Guard: never re-commit accidental nested project copies
frontend/frontend/
frontend/backend/
backend/.venv_t/
