{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Private Workspace",
  "version": "0.1.0",
  "identifier": "local.ai-private-workspace.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Private Workspace",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Local-first private AI workspace",
    "longDescription": "AI Private Workspace runs a local desktop shell, a localhost backend, and user-approved local model workflows."
  }
}
